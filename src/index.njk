---
layout: base.njk
title: null
pagination:
  data: collections.posts
  size: 7
  alias: posts
permalink: "{% if pagination.pageNumber > 0 %}/page/{{ pagination.pageNumber + 1 }}/{% else %}/{% endif %}"
---
<section class="index-intro">
  <p>musings, memories…from a mercurial madwoman</p>
</section>

<div class="entry-stream">
  {% for post in posts %}
  <article class="entry-preview">
    <header class="entry-header">
      <h2 class="entry-title"><a href="{{ prefix }}{{ post.url }}">{{ post.data.title }}</a></h2>
    </header>
    <div class="entry-body">
      {{ post.templateContent | safe }}
    </div>
    <footer class="entry-footer">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDateTime }}</time>
    </footer>
  </article>
  {% endfor %}
</div>

<nav class="pagination-nav">
  {% if pagination.href.previous %}
    <a href="{{ prefix }}{{ pagination.href.previous }}">← Newer</a>
  {% endif %}
  <span class="pagination-position">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
  {% if pagination.href.next %}
    <a href="{{ prefix }}{{ pagination.href.next }}">Older →</a>
  {% endif %}
</nav>
