<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} · {% endif %}Marginalia</title>
  <meta name="description" content="{{ description or 'A personal collection of writing, photos, and fragments.' }}">
  <link rel="stylesheet" href="/css/style.css">
  {% if extraCss %}
  <link rel="stylesheet" href="/css/{{ extraCss }}">
  {% endif %}
  <link rel="alternate" type="application/rss+xml" title="Marginalia" href="/feed.xml">
</head>
<body>
  <div class="page">
    <header class="site-header">
      <a class="site-title" href="/">Marginalia</a>
      <nav class="site-nav">
        <a href="/archive/">Archive</a>
        <a href="/tags/">Tags</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <main class="site-main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <p>Built by hand with <a href="https://www.11ty.dev/" target="_blank" rel="noopener">Eleventy</a>.</p>
    </footer>
  </div>
</body>
</html>
